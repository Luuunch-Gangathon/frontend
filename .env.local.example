# FastAPI base URL — read server-side by lib/env.ts and app/api/chat/route.ts.
# Only set NEXT_PUBLIC_API_BASE_URL if a client component ever needs to hit the
# backend directly (normally it goes through Server Components or the SSE proxy).
API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
